# --- LandingAI ADE (bring your own key) ---
# Get a key at https://va.landing.ai. The landingai-ade library reads VISION_AGENT_API_KEY.
# Without it, the server runs in STUB mode (synthetic data) so you can try the pipeline free.
VISION_AGENT_API_KEY=
LANDINGAI_ENV=            # "eu" for EU endpoints; blank for US
ADE_PARSE_MODEL=dpt-2-latest
ADE_EXTRACT_MODEL=extract-latest
CONFIDENCE_REVIEW_THRESHOLD=0.85

# --- Transport ---
MCP_TRANSPORT=stdio       # stdio (local) | streamable-http (remote)
MCP_HOST=0.0.0.0
MCP_PORT=8080

# --- Auth (remote only) — OAuth 2.1 Resource Server ---
# Remote mode requires OAuth; the server refuses to start without it.
OAUTH_ISSUER=             # e.g. https://your-tenant.us.auth0.com/
OAUTH_AUDIENCE=           # this server's API identifier/audience
MCP_RESOURCE_URL=         # this server's public URL, e.g. https://example.com/mcp
OAUTH_JWKS_URL=           # optional; defaults to <issuer>/.well-known/jwks.json
OAUTH_REQUIRED_SCOPES=    # optional CSV
MCP_DEV_BEARER_TOKEN=     # dev only: single static token (requires MCP_RESOURCE_URL)
MCP_ALLOW_INSECURE=       # run remote without auth only behind your own trusted gateway
